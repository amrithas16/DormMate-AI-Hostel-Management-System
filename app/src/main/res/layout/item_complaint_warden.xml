<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvComplaintCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Category"
            android:textColor="#7C4DFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvComplaintStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FF5252"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Open"
            android:textColor="#FF5252"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvComplaintEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="student@dormmate.com"
        android:textColor="#AAAACC"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvComplaintDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description..."
        android:textColor="#CCCCDD"
        android:textSize="13sp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etResolutionNote"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_bento_tile"
        android:hint="Resolution note..."
        android:textColor="#FFFFFF"
        android:textColorHint="#7B7B9D"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnResolve"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/bg_button_violet"
        android:text="MARK RESOLVED"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:stateListAnimator="@null" />
</LinearLayout>
