<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:backgroundTint="#CC1A1A2E"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvRoomAllocationTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Room Allocation"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etAllocateRoom"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="#1AFFFFFF"
        android:hint="Room Number (e.g. 101)"
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF"
        android:inputType="text" />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btnCancelAllocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#00000000"
            android:text="Cancel"
            android:textColor="#AAAAAA"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnSaveAllocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_violet"
            android:text="Save"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
