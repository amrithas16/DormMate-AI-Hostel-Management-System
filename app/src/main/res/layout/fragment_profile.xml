<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_aurora"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Back + Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvProfileBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="#B39DDB"
                android:textSize="14sp"
                android:paddingEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 My Profile"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Avatar Circle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_button_violet"
                android:gravity="center"
                android:text="?"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Glass Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfileName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Enter full name"
                android:textColor="#FFFFFF"
                android:textColorHint="#7B7B9D"
                android:inputType="textPersonName"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- Email (read-only) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email (cannot be changed)"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:textColor="#888888"
                android:textColorHint="#7B7B9D"
                android:inputType="textEmailAddress"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:enabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Phone Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfilePhone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Enter phone number"
                android:textColor="#FFFFFF"
                android:textColorHint="#7B7B9D"
                android:inputType="phone"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- Age & DOB -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age"
                        android:textColor="#B39DDB"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                        
                    <EditText
                        android:id="@+id/etProfileAge"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_bento_tile"
                        android:hint="Age"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7B7B9D"
                        android:inputType="number"
                        android:paddingHorizontal="12dp"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date of Birth"
                        android:textColor="#B39DDB"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                        
                    <EditText
                        android:id="@+id/etProfileDOB"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_bento_tile"
                        android:hint="DD/MM/YYYY"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7B7B9D"
                        android:inputType="date"
                        android:paddingHorizontal="12dp"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Course & Year/Sem -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Course"
                        android:textColor="#B39DDB"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                        
                    <EditText
                        android:id="@+id/etProfileCourse"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_bento_tile"
                        android:hint="e.g. B.Tech CS"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7B7B9D"
                        android:inputType="text"
                        android:paddingHorizontal="12dp"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Year / Sem"
                        android:textColor="#B39DDB"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />
                        
                    <EditText
                        android:id="@+id/etProfileYearSem"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_bento_tile"
                        android:hint="e.g. Year 2"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#7B7B9D"
                        android:inputType="text"
                        android:paddingHorizontal="12dp"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Parents Details -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Parents Details (Name &amp; Contact)"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfileParentsDetails"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Parent's Name &amp; Phone"
                android:textColor="#FFFFFF"
                android:textColorHint="#7B7B9D"
                android:inputType="textMultiLine"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:gravity="top"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home Address"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfileAddress"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="Enter home address"
                android:textColor="#FFFFFF"
                android:textColorHint="#7B7B9D"
                android:inputType="textMultiLine"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:gravity="top"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <!-- New Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Password (leave blank to keep current)"
                android:textColor="#B39DDB"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etProfilePassword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_bento_tile"
                android:hint="••••••••"
                android:textColor="#FFFFFF"
                android:textColorHint="#7B7B9D"
                android:inputType="textPassword"
                android:paddingHorizontal="12dp"
                android:textSize="15sp"
                android:layout_marginBottom="24dp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_violet"
                android:text="SAVE CHANGES"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
