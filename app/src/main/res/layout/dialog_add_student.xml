<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:backgroundTint="#CC1A1A2E"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Student Enrollment"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etNewStudentName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="#1AFFFFFF"
        android:hint="Full Name"
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF" />

    <EditText
        android:id="@+id/etNewStudentEmail"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:background="#1AFFFFFF"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF" />

    <EditText
        android:id="@+id/etNewStudentPassword"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1AFFFFFF"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF"
        android:text="123123" />

    <EditText
        android:id="@+id/etNewStudentRoom"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_glass_input"
        android:hint="Room Number (e.g. 101)"
        android:inputType="text"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/white"
        android:textColorHint="#99FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Warden can set a custom temporary password"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp" />

</LinearLayout>
