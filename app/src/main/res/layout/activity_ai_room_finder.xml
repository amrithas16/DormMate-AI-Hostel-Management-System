<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Room Finder"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/etSearchName"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="#1AFFFFFF"
        android:hint="Search Student Name..."
        android:paddingHorizontal="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#80FFFFFF"
        android:inputType="textPersonName" />

    <LinearLayout
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="#CC1A1A2E"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvResultName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Name"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvResultRoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Room: —"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvResultFloor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floor: —"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvResultWing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wing: —"
            android:textColor="#E0E0E0"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvNoResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="No student found."
        android:textColor="#FF5252"
        android:textSize="16sp"
        android:visibility="gone"
        android:layout_marginTop="24dp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_violet"
        android:text="Back to Dashboard"
        android:textColor="#FFFFFF" />

</LinearLayout>
