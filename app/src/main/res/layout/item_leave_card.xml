<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvLeaveEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="student@dormmate.com"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLeaveStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FFB300"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Pending"
            android:textColor="#FFB300"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLeaveDates"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="From: —  →  To: —"
        android:textColor="#CCCCDD"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvLeaveReason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reason: —"
        android:textColor="#AAAACC"
        android:textSize="12sp" />
</LinearLayout>
